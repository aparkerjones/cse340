<%- include("partials/header", { title }) %>
<section>
  <h1>Add New Category</h1>
  <p>Use a short, clear name so volunteers can find related projects quickly.</p>

  <form action="/new-category" method="POST" class="form-card">
    <div class="form-group">
      <label for="name">Category Name</label>
      <input
        id="name"
        name="name"
        type="text"
        required
        maxlength="100"
        placeholder="Example: Youth Mentoring"
      />
    </div>

    <button type="submit" class="cta">Create Category</button>
  </form>
</section>
<%- include("partials/footer") %>
