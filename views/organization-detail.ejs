<%- include("partials/header", { title }) %>
<section>
  <h1><%= heading %></h1>

  <img
    src="/images/<%= organization.logo_filename %>"
    alt="<%= organization.organization_name %> logo"
    class="org-image"
  />

  <p><%= organization.description %></p>

  <% if (organization.website_url) { %>
    <p>
      Website:
      <a href="<%= organization.website_url %>" target="_blank" rel="noreferrer noopener">
        <%= organization.website_url %>
      </a>
    </p>
  <% } %>

  <% if (user && user.role_name === "admin") { %>
    <p>
      <a class="cta" href="/edit-organization/<%= organization.organization_id %>">Edit Organization</a>
    </p>
  <% } %>

  <h2>Service Projects</h2>
  <% if (projects.length === 0) { %>
    <p>No service projects are currently listed for this organization.</p>
  <% } else { %>
    <ul class="item-list">
      <% projects.forEach((project) => { %>
        <li>
          <a href="/project/<%= project.project_id %>"><%= project.title %></a>
          (<%= new Date(project.project_date).toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }) %>)
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>
<%- include("partials/footer") %>
