<%- include("partials/header", { title }) %>
<section>
  <h1>Add New Service Project</h1>

  <form action="/new-project" method="POST" class="form-card">
    <div class="form-group">
      <label for="organizationId">Organization</label>
      <select id="organizationId" name="organizationId" required>
        <option value="">Select an organization</option>
        <% organizations.forEach((organization) => { %>
          <option value="<%= organization.organization_id %>">
            <%= organization.organization_name %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="title">Project Title</label>
      <input id="title" name="title" type="text" required maxlength="120" />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        required
        maxlength="1000"
      ></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <input id="location" name="location" type="text" required maxlength="120" />
    </div>

    <div class="form-group">
      <label for="date">Date</label>
      <input id="date" name="date" type="date" required />
    </div>

    <button type="submit" class="cta">Create Project</button>
  </form>
</section>
<%- include("partials/footer") %>
