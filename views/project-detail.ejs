<%- include("partials/header", { title }) %>
<section>
  <h1><%= heading %></h1>

  <p><%= project.description %></p>
  <p><strong>Location:</strong> <%= project.location %></p>
  <p>
    <strong>Date:</strong>
    <%= new Date(project.project_date).toLocaleDateString("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    }) %>
  </p>
  <p>
    <strong>Partner Organization:</strong>
    <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
  </p>
  <% if (user && user.role_name === "admin") { %>
    <p>
      <a class="cta" href="/project/<%= project.project_id %>/assign-categories">Edit Categories</a>
      <a class="cta" href="/edit-project/<%= project.project_id %>">Edit Project</a>
    </p>
  <% } %>

  <h2>Categories</h2>
  <% if (categories.length === 0) { %>
    <p>This project currently has no categories assigned.</p>
  <% } else { %>
    <div class="tag-list" aria-label="Project categories">
      <% categories.forEach((category) => { %>
        <a class="tag" href="/category/<%= category.category_id %>"><%= category.category_name %></a>
      <% }) %>
    </div>
  <% } %>
</section>
<%- include("partials/footer") %>
