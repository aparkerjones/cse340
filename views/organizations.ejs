<%- include("partials/header", { title }) %>
<section>
  <h1><%= heading %></h1>
  <p><%= description %></p>
  <div class="org-grid">
    <% items.forEach((organization) => { %>
      <article class="org-card">
        <img
          src="/images/<%= organization.logo_filename %>"
          alt="<%= organization.organization_name %> logo"
          class="org-image"
        />
        <h2><%= organization.organization_name %></h2>
        <p><strong>Email:</strong> <a href="mailto:<%= organization.contact_email %>"><%= organization.contact_email %></a></p>
        <p><%= organization.description %></p>
        <% if (organization.website_url) { %>
          <p><a href="<%= organization.website_url %>" target="_blank" rel="noreferrer">Visit website</a></p>
        <% } %>
      </article>
    <% }) %>
  </div>
</section>
<%- include("partials/footer") %>
